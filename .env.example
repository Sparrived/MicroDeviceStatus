# Copy to .env next to docker-compose.yml (never commit real secrets).
MDS_ADMIN_TOKEN=replace-with-a-long-random-token
MDS_ADMIN_USERNAME=admin
MDS_ADMIN_PASSWORD=replace-with-a-long-password
# Optional public read-only snapshot credentials. Keep this token server-side.
MDS_PUBLIC_STATUS_TOKEN=replace-with-a-separate-long-read-only-token
MDS_PUBLIC_DEVICE_IDS=computer-device-id,phone-device-id
MDS_STATUS_ONLINE_SECONDS=300
MDS_STATUS_STALE_SECONDS=1800
MDS_REPORT_RETENTION_DAYS=30
# Set to 1 when browsers reach the service over HTTPS (reverse proxy / TLS).
MDS_COOKIE_SECURE=0
