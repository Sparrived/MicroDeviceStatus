<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mds_paper"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MDS Mobile"
            android:textColor="@color/mds_ink"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="设备状态上报客户端"
            android:textColor="@color/mds_muted"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="服务地址"
            android:textColor="@color/mds_ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/endpoint_input"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_background"
            android:hint="例如 http://10.0.2.2:8080"
            android:inputType="textUri"
            android:singleLine="true"
            android:textColor="@color/mds_ink"
            android:textColorHint="@color/mds_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="设备令牌"
            android:textColor="@color/mds_ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/token_input"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_background"
            android:hint="创建设备时返回的 token"
            android:inputType="textPassword"
            android:singleLine="true"
            android:textColor="@color/mds_ink"
            android:textColorHint="@color/mds_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="上报间隔（秒）"
            android:textColor="@color/mds_ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/interval_input"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_background"
            android:inputType="number"
            android:singleLine="true"
            android:text="60"
            android:textColor="@color/mds_ink" />

        <CheckBox
            android:id="@+id/location_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="上报当前位置"
            android:textColor="@color/mds_ink"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="默认关闭。开启后需要授予定位权限，心跳只包含国家、省、市、区。"
            android:textColor="@color/mds_muted"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/auto_resume_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="开机自动恢复上报"
            android:textColor="@color/mds_ink"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/usage_access_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="使用情况访问权限：未授予，前台应用将显示为空"
            android:textColor="@color/mds_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/usage_access_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="设置前台应用访问权限"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/battery_optimization_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="设置后台运行不受限制"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/status_background"
            android:text="尚未启动"
            android:textColor="@color/mds_teal_dark"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/start_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="开始监控"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/stop_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="停止"
                android:textAllCaps="false" />
        </LinearLayout>

        <Button
            android:id="@+id/send_now_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="立即上报"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="客户端会采集内存、存储、电量、网络和当前应用信息。网络中断时，心跳会保存在本机并在恢复后补发。请允许通知、后台运行和不受限制的电池使用；部分手机还需要手动开启自启动。生产环境请使用 HTTPS。"
            android:textColor="@color/mds_muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
